{
  "name": "claudio-content-empire",
  "version": "1.0.0",
  "description": "Claudio's nonstop article generation empire with scheduled batch processing.",
  "main": "claudio-orchestrator.js",
  "type": "commonjs",
  "scripts": {
    "start": "node claudio-orchestrator.js --full-empire",
    "orchestrate": "node claudio-orchestrator.js --full-empire",
    "pipeline": "node article-pipeline.js",
    "generate:article": "node article-generator.js",
    "validate": "node claudio-orchestrator.js --validate-only",
    "batch": "npm run pipeline && npm run orchestrate"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  }
}
