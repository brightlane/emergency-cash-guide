name: MaxLend Nonstop
on:
  schedule:
    - cron: '*/20 * * * *'  # every 20 min
  workflow_dispatch:

jobs:
  run:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: 20 }
      - run: npm ci
      - name: Claudio Blueprint
        run: |
          ls output/ || echo "no output"
          node output/claudio-orchestrator.js || true
          node output/task-runner.js || true
          node output/generate-sitemap.js || true
      - name: Deploy Site
        uses: actions/upload-pages-artifact@v3
        with:
          path: output/site/
